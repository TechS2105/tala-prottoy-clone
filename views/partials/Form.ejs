<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/Form/Form.css">
</head>
<body>
    
    <!-- Form Section -->
    <div class="form-section">

        <% if(pageName !== 'skill-development') { %> 
        
            <span> Fill & Submit </span>
            
        <% } %>

        <form action="<%= actionURL %>" method="post">

            <!-- First Input -->
            <div class="first-input">

                <% if(pageName !== 'advertisement'){ %> 
                
                    <input type="text" id="name" placeholder="Your Name *" name="fullname" required>
                    
                <% } %> 
                
                <% if(pageName === 'skill-development' && pageName !== 'contact'){ %>

                    <input type="tel" id="mobile" name="mobile" placeholder="Number *" required>

                <% } %>

            </div>

            <!-- Second Input -->
            <% if(pageName === 'contact' || pageName === 'skill-development'|| pageName === 'art-walk-through' || pageName === 'privilege-entry'){ %> 

                <div class="second-input">

                    <input type="email" id="mail" name="email"  placeholder="Your Email *" required>

                    <% if(pageName === 'contact' || pageName === 'art-walk-through' || pageName === 'privilege-entry'){ %> 
                    
                        <input type="tel" id="mobile" name="mobile"  placeholder="Your Number *" minlength="10" maxlength="10" required>
                        
                    <% } %> 
                    
                    <% if(pageName === 'skill-development') { %> 
                    
                        <input type="text" id="specialiation" name="specialiation" placeholder="Specialiation *" required>
                        
                    <% } %>

                </div>

            <% } %>

            <!-- Additional Inputs Page Wise -->
            <% if(pageName === 'art-walk-through' || pageName === 'privilege-entry' && pageName !== 'skill-development') { %> 
                
                <!-- Art Work Page Input -->
                <div class="artwork-input">

                    <input type="text" id="address" name="address" placeholder="Address *" required>

                </div>

                <!-- No Of Guest -->
                <div class="no-of-guest">

                    <select name="guestno" id="guestno">

                        <option value="No Of Guest" hidden> No Of Guest </option>
                        <option value="1">1</option>
                        <option value="2">2</option>

                    </select>

                </div>

                <!-- Date Input -->
                <div class="calender-input">

                    <input type="date" name="date" id="date" required>

                </div>

                <!-- Time Input -->
                <div class="time-input">

                    <select name="time" id="time">

                        <option value="Select Time" hidden> Select Time </option>
                        <option value="6 PM"> 6 PM </option>
                        <option value="9 PM"> 9 PM </option>
                        <option value="12 AM"> 12 AM </option>

                    </select>

                </div>
                
            <% } %>

            <% if(pageName === 'privilege-entry') { %> 
            
                <!-- Reason Input -->
                <div class="reason-input">

                    <select name="reason" id="reason">

                        <option value="Select Reason" hidden> Select Reason </option>
                        <option value="Differently abled person"> Differently abled person </option>
                        <option value="Aged person with restrited movement"> Aged person with restrited movement </option>
                        <option value="Pregnant"> Pregnant </option>
                        <option value="National Security Force | Police"> National Security Force | Police </option>
                        <option value="Journalist | Media Person"> Journalist | Media Person </option>
                        <option value="Artist | Galleriest"> Artist | Galleriest </option>
                        <option value="Art Curator | Art Researcher"> Art Curator | Art Researcher </option>
                        <option value="Foreigner | NRI"> Foreigner | NRI </option>

                    </select>

                </div>
                
            <% } %>

            <% if(pageName === 'advertisement'){ %> 
            
                <!-- Advertisement Page Form -->
                <div class="advertisement-page-form">

                    <!-- Form Input Box Section -->
                    <div class="form-input-box-section">

                        <!-- Company Name -->
                        <div class="company-name-input">

                            <input type="text" placeholder="Company Name *" id="company-name" name="companyname" required>

                        </div>

                        <!-- Contact Person Name -->
                        <div class="contact-person-name">

                            <input type="text" placeholder="Contact Person Name *" id="contact-person-name" name="contactpersonname" required> 

                        </div>

                        <!-- Designation -->
                        <div class="designation">

                            <input type="text" placeholder="Designation *" id="designation" name="designation" required>

                        </div>

                        <!-- Contact No -->
                        <div class="contact-no">

                            <input type="tel" placeholder="Contact No. *" id="mobile" name="mobile" required>

                        </div>

                        <!-- Email -->
                        <div class="email">

                            <input type="email" placeholder="Email *" id="email" name="email" required>

                        </div>

                    </div>
                    
                    <!-- Interested Check Box Section -->
                    <div class="interested-check-box-section">

                        <h3> Interested in </h3>

                        <ul>

                            <li>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Led Wowt"> Led Wowt

                                </span>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" id="Led Anamorphic"> Led Anamorphic

                                </span>
                            
                            </li>

                            <li>
                                
                                <span>

                                    <input type="checkbox" name="interested[] " value="Led Sky High "> Led Sky High

                                </span>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Overhead Gate"> Overhead Gate

                                </span>
                            
                            </li>

                            <li>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Tunnel"> Tunnel

                                </span>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Side Wall"> Side Wall

                                </span>
                            
                            </li>

                            <li>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Hoarding"> Hoarding

                                </span>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Back-lit Tower"> Back-lit Tower

                                </span>
                            
                            </li>

                            <li>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Drop Down"> Drop Down

                                </span>
                                
                                <span>

                                    <input type="checkbox" name="interested[]" value="Pavilion"> Pavilion

                                </span>
                            
                            </li>

                        </ul>

                    </div>

                </div>
                
            <% } %> 

            <!-- Text Area -->
            <% if(pageName === 'contact' || pageName === 'skill-development'){ %> 
            
                <div class="third-input">

                    <textarea name="message" id="message" placeholder="Message *"  required></textarea>

                </div>
                
            <% } %>
            

            <!-- Button -->
            <div class="button-section">

                <button type="submit">
                
                    <% if(pageName === 'contact') { %> 
                    
                        Send Message 

                    <% } else { %> 
                    
                        Submit
                        
                    <% } %>
                    
                </button>

            </div>

        </form>

    </div>

</body>
</html>